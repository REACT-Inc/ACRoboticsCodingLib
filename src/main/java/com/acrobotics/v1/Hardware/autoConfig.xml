        <LynxModule name="Expansion Hub 2" port="2">
            %<MOTOR_TYPE_EXP name="MOTOR_NAME" port="MOTOR_PORT" />%
            %<SERVO_TYPE_EXP name="SERVO_NAME" port="SERVO_PORT" />%
        </LynxModule>
        <LynxModule name="Control Hub" port="173">
            %<MOTOR_TYPE_CTRL name="MOTOR_NAME" port="MOTOR_PORT" />%
            %<SERVO_TYPE_CTRL name="SERVO_NAME" port="SERVO_PORT" />%
            <RevTouchSensor name="touch2" port="2" />
            <RevTouchSensor name="touch3" port="3" />
            <goBILDAPinpoint name="pinpoint" port="0" bus="3" />
        </LynxModule>
    </LynxUsbDevice>
</Robot>
